# Silent Voice — project-root .env
# -------------------------------------------------
# This file is read when scripts are run from the project root.
# The canonical copy lives at ai-pc/.env — keep both in sync.

# ---- Provider selection ----
# "sarvam"  → try Sarvam AI first, auto-fall back to pyttsx3 on any failure
# "pyttsx3" → always offline (no network calls made)
SPEECH_PROVIDER=sarvam

# ---- Sarvam AI credentials ----
# Get your key at: https://dashboard.sarvam.ai
SARVAM_API_KEY=sk_g37tu0kk_pzAcRKFIWTaYDhAnRliTXNYv


# ---- Sarvam AI model / voice settings ----
SARVAM_LANGUAGE=en-IN
SARVAM_SPEAKER=shubh
SARVAM_MODEL=bulbul:v3
SARVAM_TIMEOUT_SECONDS=8

# ---- Offline TTS settings ----
SPEECH_RATE=165
